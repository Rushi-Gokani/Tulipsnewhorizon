        "custom_liquid": "{% assign mobile_banner = collection.metafields.custom.mobile_banner %}\n\n<div class=\"collection-banner\">\n  \n  {% if collection.image %}\n    <img\n      class=\"banner-desktop\"\n      src=\"{{ collection.image | image_url: width: 2000 }}\"\n      alt=\"{{ collection.title }}\"\n      loading=\"lazy\">\n  {% endif %}\n\n  {% if mobile_banner %}\n    <img\n      class=\"banner-mobile\"\n      src=\"{{ mobile_banner | image_url: width: 1000 }}\"\n      alt=\"{{ collection.title }}\"\n      loading=\"lazy\">\n  {% elsif collection.image %}\n    <img\n      class=\"banner-mobile\"\n      src=\"{{ collection.image | image_url: width: 1000 }}\"\n      alt=\"{{ collection.title }}\"\n      loading=\"lazy\">\n  {% endif %}\n\n</div>\n\n<style>\n.collection-banner img{\n    width:100%;\n    display:block;\n}\n\n.banner-mobile{\n    display:none;\n}\n\n@media (max-width: 767px){\n    .banner-desktop{\n        display:none;\n    }\n\n    .banner-mobile{\n        display:block;\n    }\n}\n</style>",
