                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_MnO678"
              ]
            },
            "accordion_row_PqR901": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "Are TULIPS adult diapers disposable or reusable?",
                "open_by_default": false,
                "hide_if_empty": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_StU234": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>These are single use diapers in which the user can urinate number of times depending on its absorbency<br/>capacity. Once it is taken off, the used diaper should be wrapped and disposed-off, in a dry waste bin. Do not<br/>flush adult diapers in the toilet.</p>",
                    "enable_read_more": false,
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
