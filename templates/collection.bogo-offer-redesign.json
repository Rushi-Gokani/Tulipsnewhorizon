            },
            "accordion_row_NFBwDt": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "Are TULIPS Adult Diaper pants suitable for Leak protection during Night?",
                "open_by_default": false,
                "hide_if_empty": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_44UbDR": {
                  "type": "text",
                  "settings": {
