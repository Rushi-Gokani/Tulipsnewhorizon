              },
              "block_order": [
                "text_StU234"
              ]
            },
            "accordion_row_37tTG3": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "Having worn underwear all my life, One cannot even think of wearing something different. Then how do I think of wearing an Adult Diaper?",
                "open_by_default": false,
                "hide_if_empty": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_LpM8z4": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Adult Diaper Pants are designed in the shape of an underwear, to give a feel to the user that they are<br/>wearing something like a normal underwear only. It is worn like any other regular underwear.</p>",
                    "enable_read_more": false,
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
