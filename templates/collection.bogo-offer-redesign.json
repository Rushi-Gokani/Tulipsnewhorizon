              ]
            },
            "accordion_row_WPVGVa": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "What if Adult Diaper leaks in public. Wouldn’t that be so embarrassing?",
                "open_by_default": false,
                "hide_if_empty": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_CNzrr6": {
                  "type": "text",
                  "settings": {
                    "text": "<p>A TULIPS Adult Diaper pants have a 1000 ml absorption power. Based on this absorption capacity, it has a<br/>tentative absorption protection of up-to 10 hours. This high absorption capacity with its other supporting<br/>features gives a super confidence that the diaper would not leak when one is out in travel/ public place.</p>",
                    "enable_read_more": false,
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_size": "1rem",
                    "line_height": "normal",
                    "letter_spacing": "normal",
                    "case": "none",
