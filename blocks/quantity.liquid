

{% render 'quantity-selector', product: closest.product, custom_max: block.settings.quantity_limit %}

{% schema %}
{
  "name": "t:names.quantity",
  "tag": null,
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_quantity_limit",
      "label": "Enable quantity limit",
      "default": false
    },
    {
      "type": "range",
      "id": "quantity_limit",
      "label": "Maximum quantity",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 10,
      "info": "Maximum quantity a user can add to cart",
      "visible_if": "{{ block.settings.enable_quantity_limit == true }}"
    }
  ]
}
{% endschema %}
