{%- comment -%}
  Accepts:

  -class: {String} - Class to be applied
  -alignment?: {String} - Alignemnt of the links. Accepts: 'center'
  -product_collection?: {Collection} - Add's first collection if assigned to the breadcrumb
{%- endcomment -%}

{%- assign alignment = alignment | default: '' -%}
{%- assign class = class | default: '' | append: 'breadcrumbs--' | append: alignment -%}

<nav class="breadcrumbs {{ class }} {{ template.name }}__breadcrumbs" role="navigation" aria-label="{{- 'theme.breadcrumb.label' | t -}}">
  <ul class="breadcrumbs__list list-unstyled no-scrollbar" role="list">
    <li>
      <a href="{{- routes.root_url -}}" class="breadcrumbs__link">
        {{- 'theme.breadcrumb.home' | t -}}
      </a>
    </li>

    <li class="breadcrumbs__separator">/</li>

    {%- if product -%}
      {%- liquid
        assign target_collection = blank
        if collection and collection.handle != blank and collection.handle != 'all'
          assign col_handle = collection.handle | downcase
          unless col_handle contains 'all-products' or col_handle contains '18-gst' or col_handle == '5' or col_handle contains '12-gst'
            assign target_collection = collection
          endunless
        elsif product.collections.size > 0
          for col in product.collections
            if col.handle != blank and col.handle != 'all'
              assign col_handle = col.handle | downcase
              unless col_handle contains 'all-products' or col_handle contains '18-gst' or col_handle == '5' or col_handle contains '12-gst'
                assign target_collection = col
                break
              endunless
            endif
          endfor
        endif
      -%}
      {%- if target_collection -%}
        <li>
          <a href="{{- target_collection.url -}}" class="breadcrumbs__link">
            {{- target_collection.title | escape -}}
          </a>
        </li>
        <li class="breadcrumbs__separator">/</li>
      {%- endif -%}
    {%- endif -%}

    {%- if product_collection -%}
      <li>
        <a href="{{- product_collection.url -}}" class="breadcrumbs__link">
          {{- product_collection.title | escape -}}
        </a>
      </li>

      <li class="breadcrumbs__separator">/</li>
    {%- endif -%}

    {%- if template.name == 'article' -%}
      <li>
        <a href="{{- blog.url -}}" class="breadcrumbs__link" title="{{- blog.title | escape -}}">
          {{- blog.title | escape -}}
        </a>
      </li>
      <li class="breadcrumbs__separator">/</li>
    {%- endif -%}
    <li>
      <span>
        {%- if template.name != 'search' -%}
          {{- page_title | escape -}}
        {%- else -%}
          {{- 'theme.breadcrumb.search' | t -}}
        {%- endif -%}
      </span>
    </li>
  </ul>
</nav>
