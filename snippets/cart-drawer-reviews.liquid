{% stylesheet %}
  .cart-drawer-reviews {
    padding: 16px 12px 12px;
    border-top: 1px solid var(--color-border);
    background-color: var(--color-background);
    flex-shrink: 0;
  }

  .cart-drawer-reviews__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
    padding: 0 14px;
  }

  .cart-drawer-reviews__heading {
    font-size: 18px;
    font-weight: var(--font-weight-bold);
    color: var(--color-foreground);
    margin: 0;
    letter-spacing: 0.02em;
  }

  .cart-drawer-reviews__nav {
    display: flex;
    gap: 6px;
  }

  .cart-drawer-reviews__nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-background);
    color: var(--color-foreground);
    cursor: pointer;
    transition: all 0.2s ease;
    padding: 0;
  }

  .cart-drawer-reviews__nav-btn:hover {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }

  .cart-drawer-reviews__nav-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .cart-drawer-reviews__nav-btn:disabled:hover {
    background: var(--color-background);
    color: var(--color-foreground);
    border-color: var(--color-border);
  }

  .cart-drawer-reviews__track {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 4px 8px 8px 8px;
    scrollbar-width: none;
  }

  .cart-drawer-reviews__track::-webkit-scrollbar {
    display: none;
  }

  .cart-drawer-reviews__card {
    flex: 0 0 calc(100% - 16px);
    min-width: 0;
    max-width: none;
    scroll-snap-align: center;
    background: rgb(var(--color-foreground-rgb) / 0.025);
    border: 1px solid rgb(var(--color-border-rgb) / 0.4);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .cart-drawer-reviews__card:hover {
    border-color: rgb(var(--color-border-rgb));
    box-shadow: 0 2px 12px rgb(var(--color-shadow-rgb) / 0.06);
  }

  .cart-drawer-reviews__stars {
    display: flex;
    gap: 2px;
  }

  .cart-drawer-reviews__star {
    fill: rgb(var(--color-border-rgb) / 0.25);
    transition: fill 0.2s ease;
  }

  .cart-drawer-reviews__star--filled {
    fill: #FFB800;
  }

  .cart-drawer-reviews__text {
    font-size: 13px;
    line-height: 1.55;
    color: rgb(var(--color-foreground-rgb) / 0.8);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cart-drawer-reviews__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    padding-top: 6px;
  }

  .cart-drawer-reviews__author {
    font-size: 12px;
    font-weight: var(--font-weight-bold);
    color: var(--color-foreground);
  }

  .cart-drawer-reviews__verified {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 10px;
    color: #22c55e;
    font-weight: 600;
  }

  .cart-drawer-reviews__verified svg {
    stroke: #22c55e;
  }

  .cart-drawer-reviews__scroll-indicator {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-top: 10px;
  }

  .cart-drawer-reviews__scroll-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgb(var(--color-border-rgb) / 0.4);
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .cart-drawer-reviews__scroll-dot--active {
    background: var(--color-foreground);
    width: 18px;
    border-radius: 3px;
  }
{% endstylesheet %}

{% liquid
  assign reviews_enabled = settings.cart_drawer_reviews_enabled
  assign review_heading = settings.cart_drawer_review_heading | default: 'Customer Reviews'
-%}

{%- if reviews_enabled -%}
  <cart-drawer-reviews is="cart-drawer-reviews" data-cart-drawer-reviews>
    <div class="cart-drawer-reviews__header">
      <h3 class="cart-drawer-reviews__heading">{{ review_heading }}</h3>
      <div class="cart-drawer-reviews__nav">
        <button
          type="button"
          class="cart-drawer-reviews__nav-btn cart-drawer-reviews__nav-btn--prev"
          aria-label="Previous reviews"
          data-reviews-prev
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          type="button"
          class="cart-drawer-reviews__nav-btn cart-drawer-reviews__nav-btn--next"
          aria-label="Next reviews"
          data-reviews-next
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="cart-drawer-reviews__track" data-reviews-track>
      {%- for i in (1..6) -%}
        {% liquid
          capture author_key
            echo 'cart_drawer_review_' | append: i | append: '_author'
          endcapture
          capture rating_key
            echo 'cart_drawer_review_' | append: i | append: '_rating'
          endcapture
          capture text_key
            echo 'cart_drawer_review_' | append: i | append: '_text'
          endcapture
          capture verified_key
            echo 'cart_drawer_review_' | append: i | append: '_verified'
          endcapture

          assign current_author = settings[author_key]
          assign current_rating = settings[rating_key]
          assign current_text = settings[text_key]
          assign current_verified = settings[verified_key]
        -%}

        {%- if current_author != blank and current_text != blank -%}
          <div class="cart-drawer-reviews__card" data-review-card>
            <div class="cart-drawer-reviews__stars">
              {%- for star in (1..5) -%}
                <svg
                  class="cart-drawer-reviews__star {% if forloop.index <= current_rating %}cart-drawer-reviews__star--filled{% endif %}"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {%- endfor -%}
            </div>

            <p class="cart-drawer-reviews__text">{{ current_text }}</p>

            <div class="cart-drawer-reviews__meta">
              <span class="cart-drawer-reviews__author">{{ current_author }}</span>
              {%- if current_verified -%}
                <span class="cart-drawer-reviews__verified">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M9 12L11 14L15 10M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  Verified
                </span>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="cart-drawer-reviews__scroll-indicator" data-reviews-indicator></div>
  </cart-drawer-reviews>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }},
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "reviewCount": "1500",
        "bestRating": "5"
      },
      "review": [
        {%- for i in (1..6) -%}
          {% liquid
            capture author_key
              echo 'cart_drawer_review_' | append: i | append: '_author'
            endcapture
            capture rating_key
              echo 'cart_drawer_review_' | append: i | append: '_rating'
            endcapture
            capture text_key
              echo 'cart_drawer_review_' | append: i | append: '_text'
            endcapture

            assign current_author = settings[author_key]
            assign current_rating = settings[rating_key]
            assign current_text = settings[text_key]
          -%}
          {%- if current_author != blank and current_text != blank -%}
            {
              "@type": "Review",
              "author": {
                "@type": "Person",
                "name": {{ current_author | json }}
              },
              "reviewRating": {
                "@type": "Rating",
                "ratingValue": {{ current_rating | json }},
                "bestRating": "5"
              },
              "reviewBody": {{ current_text | json }}
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
  </script>

  <script src="{{ 'cart-drawer-reviews.js' | asset_url }}" type="module" fetchpriority="low"></script>
{%- endif -%}
