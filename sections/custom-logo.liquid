{%- style -%}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    display: flex;
    justify-content: {{ section.settings.alignment }};
    align-items: center;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .section-{{ section.id }} .custom-logo-image {
    max-width: 100%;
    object-fit: contain;
  }
  
  {% if section.settings.logo_width != 0 %}
  .section-{{ section.id }} .custom-logo-image {
    width: {{ section.settings.logo_width }}px;
  }
  {% else %}
  .section-{{ section.id }} .custom-logo-image {
    width: auto;
  }
  {% endif %}

  {% if section.settings.logo_height != 0 %}
  .section-{{ section.id }} .custom-logo-image {
    height: {{ section.settings.logo_height }}px;
  }
  {% else %}
  .section-{{ section.id }} .custom-logo-image {
    height: auto;
  }
  {% endif %}
  
  .section-{{ section.id }} .placeholder-svg {
    background-color: #f3f3f3;
    color: #ccc;
    {% if section.settings.logo_width == 0 %}width: 150px;{% endif %}
    {% if section.settings.logo_height == 0 %}height: 150px;{% endif %}
  }
{%- endstyle -%}

<div class="custom-logo-section section-{{ section.id }} page-width">
  {%- if section.settings.logo != blank -%}
    {{ section.settings.logo | image_url: width: 2000 | image_tag: class: 'custom-logo-image', loading: 'lazy' }}
  {%- else -%}
    {{ 'image' | placeholder_svg_tag: 'placeholder-svg custom-logo-image' }}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Custom Logo",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 0,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Logo Width",
      "default": 150,
      "info": "Set to 0 to use auto width."
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 0,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Logo Height",
      "default": 0,
      "info": "Set to 0 to use auto height (preserves aspect ratio)."
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Custom Logo",
      "category": "Image"
    }
  ]
}
{% endschema %}
