{{ 'section-featured-collection-carousel.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign raw_url = section.settings.video_url | strip
  if raw_url contains 'shorts/'
    assign promo_video_id = raw_url | split: 'shorts/' | last | split: '?' | first
  elsif raw_url contains 'youtu.be/'
    assign promo_video_id = raw_url | split: 'youtu.be/' | last | split: '?' | first
  elsif raw_url contains 'watch?v='
    assign promo_video_id = raw_url | split: 'watch?v=' | last | split: '&' | first
  else
    assign promo_video_id = raw_url
  endif
-%}

{%- style -%}
  .tulip-promo-section {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .tulip-promo-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .tulip-promo-layout {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 40px;
    flex-wrap: wrap;
  }

  .tulip-promo-product {
    flex: 0 0 auto;
    width: 280px;
  }

  .tulip-promo-video-col {
    flex: 0 0 auto;
    width: 280px;
  }

  .tulip-promo-video-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    background: #1a1a1a;
    border-radius: 12px;
    overflow: hidden;
  }

  .tulip-promo-video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .tulip-promo-video-wrapper iframe.is-playing {
    opacity: 1;
  }

  .tulip-promo-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 13px;
    text-align: center;
    padding: 20px;
    gap: 12px;
    cursor: pointer;
    background-image: var(--thumb-url);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .tulip-promo-placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 0;
  }

  .tulip-promo-play-btn {
    position: relative;
    z-index: 1;
    width: 68px;
    height: 68px;
    border-radius: 50%;
    border: 3px solid rgba(255,255,255,0.9);
    background: rgba(255,255,255,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, transform 0.2s;
    flex-shrink: 0;
  }

  .tulip-promo-placeholder:hover .tulip-promo-play-btn {
    background: rgba(255,255,255,0.3);
    transform: scale(1.08);
  }

  .tulip-promo-play-label {
    position: relative;
    z-index: 1;
    color: rgba(255,255,255,0.9);
    font-size: 13px;
    text-shadow: 0 1px 3px rgba(0,0,0,0.6);
  }

  .product-judgeme-reviews {
    margin-bottom: 10px;
    min-height: 20px;
  }

  @media screen and (max-width: 749px) {
    .tulip-promo-product,
    .tulip-promo-video-col {
      width: 100%;
      max-width: 320px;
    }
  }
{%- endstyle -%}

<div class="tulip-promo-section">
  <div class="page-width">

    {%- if section.settings.heading != blank -%}
      <div class="title-wrapper-with-link title-wrapper--self-padded-mobile title-wrapper--no-top-margin centered" style="margin-bottom: 30px;">
        <h2 class="title {{ section.settings.heading_size }} center">
          {{ section.settings.heading | escape }}
        </h2>
      </div>
    {%- endif -%}

    <div class="tulip-promo-layout">

      <!-- Product Card -->
      {%- if section.settings.product != blank -%}
        {%- assign promo_product = section.settings.product -%}
        <div class="tulip-promo-product">
          {% capture product_card_content %}
            {% capture gallery_children %}
              <div class="product-badges product-badges--top-left">
                {%- if promo_product.compare_at_price > promo_product.price -%}
                  {% assign discount = promo_product.compare_at_price | minus: promo_product.price | times: 100.0 | divided_by: promo_product.compare_at_price | round %}
                  <div class="product-badges__badge product-badges__badge--custom">{{ discount }}% OFF</div>
                {%- endif -%}
                {%- if promo_product.available == false -%}
                  <div class="product-badges__badge product-badges__badge--custom">SOLD OUT</div>
                {%- endif -%}
              </div>
            {% endcapture %}
            {% render 'card-gallery', product: promo_product, children: gallery_children %}
            <div class="card-info" style="padding: 15px;">
              <h3 class="card-title h5" style="margin: 0 0 5px;">
                <a href="{{ promo_product.url }}" class="full-unstyled-link" style="text-decoration: none; color: inherit;">
                  {{ promo_product.title }}
                </a>
              </h3>
              <div class="product-judgeme-reviews">
                <div class='jdgm-widget jdgm-preview-badge' data-id='{{ promo_product.id }}'>
                  {{ promo_product.metafields.judgeme.badge }}
                </div>
              </div>
              <div style="margin-bottom: 15px;">
                {% render 'price', product_resource: promo_product, show_compare_price: true %}
              </div>
              {% render 'product-card-button', product: promo_product %}
            </div>
          {% endcapture %}
          {% render 'product-card', product: promo_product, children: product_card_content %}
        </div>
      {%- endif -%}

      <!-- Video (9:16 — autoplays after delay when in view) -->
      <div class="tulip-promo-video-col">
        <div class="tulip-promo-video-wrapper" id="tulip-promo-wrapper-{{ section.id }}">
          <div class="tulip-promo-placeholder" id="tulip-promo-placeholder-{{ section.id }}"
               style="--thumb-url: url('https://img.youtube.com/vi/{{ promo_video_id }}/hqdefault.jpg')">
            <div class="tulip-promo-play-btn">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
            <div class="tulip-promo-play-label">Tap to play now</div>
          </div>
          <iframe
            id="tulip-promo-iframe-{{ section.id }}"
            src="about:blank"
            data-video-id="{{ promo_video_id }}"
            data-delay="{{ section.settings.autoplay_delay | times: 1000 }}"
            allow="autoplay; encrypted-media; picture-in-picture"
            allowfullscreen
            title="{{ section.settings.heading | escape }} Video">
          </iframe>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  (function() {
    var sid = '{{ section.id }}';
    var iframe = document.getElementById('tulip-promo-iframe-' + sid);
    var placeholder = document.getElementById('tulip-promo-placeholder-' + sid);
    var wrapper = document.getElementById('tulip-promo-wrapper-' + sid);
    if (!iframe || !wrapper) return;

    var videoId = iframe.getAttribute('data-video-id');
    var totalMs = parseInt(iframe.getAttribute('data-delay'), 10);
    var played = false;

    function playVideo() {
      if (played) return;
      played = true;
      if (placeholder) placeholder.style.display = 'none';
      iframe.src = 'https://www.youtube.com/embed/' + videoId
        + '?autoplay=1&mute=1&loop=1&playlist=' + videoId + '&playsinline=1&rel=0';
      iframe.classList.add('is-playing');
    }

    // Click play button to start instantly
    if (placeholder) placeholder.addEventListener('click', playVideo);

    // Auto-play after delay once section is in view
    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function(entries) {
        if (entries[0].isIntersecting) {
          setTimeout(playVideo, totalMs);
          observer.disconnect();
        }
      }, { threshold: 0.3 });
      observer.observe(wrapper);
    } else {
      setTimeout(playVideo, totalMs);
    }
  })();
</script>

{% schema %}
{
  "name": "Tulip Promo Section",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "TULIPS WET WIPES X COKTAIL 2 PROMOTION",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Combo Offer Product"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "YouTube Video URL",
      "default": "https://youtube.com/shorts/wQU0dRie-Js",
      "info": "Paste a YouTube or YouTube Shorts URL"
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "min": 5,
      "max": 60,
      "step": 5,
      "default": 25,
      "unit": "s",
      "label": "Autoplay after (seconds)"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Tulip Promo Section"
    }
  ],
  "blocks": [
    {
      "type": "judgeme_reviews",
      "name": "Judge.me Reviews",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "Show Judge.me review stars on the combo product."
        },
        {
          "type": "checkbox",
          "id": "show_text",
          "label": "Show review text",
          "default": true
        }
      ]
    }
  ]
}
{% endschema %}
