{{- 'contact-boxes.css' | asset_url | stylesheet_tag -}}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous">

<section class="contact-boxes-wrapper">
  <div class="contact-boxes">
    <div class="contact-box">
      <h3>
        {{ section.settings.customer_service_title }}
        <i class="fas fa-paper-plane"></i>
      </h3>
      <p>{{ section.settings.customer_service_desc }}</p>
      <a href="mailto:{{ section.settings.customer_service_email }}">
        {{ section.settings.customer_service_email }}
        <i class="fas fa-envelope"></i>
      </a>
    </div>

    <div class="contact-box">
      <h3>
        {{ section.settings.helpline_title }}
        <i class="fas fa-headset"></i>
      </h3>
      <p>{{ section.settings.helpline_desc }}</p>
      <a href="tel:{{ section.settings.helpline_phone }}">
        {{ section.settings.helpline_phone }}
        <i class="fas fa-phone"></i>
      </a>
    </div>
  </div>

  <!-- Address Box -->
  <section class="address-box">
    <div class="contact-box">
      <h3>
        {{ section.settings.address_title }}
        <i class="fas fa-map-marker-alt"></i>
      </h3>
      <p>{{ section.settings.address_details }}</p>
      <a href="tel:{{ section.settings.additional_phone }}">
        {{ section.settings.additional_phone }}
        <i class="fas fa-phone-alt"></i>
      </a>
    </div>
  </section>
</section>

{% schema %}
{
  "name": "Contact Boxes",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Customer Service Box"
    },
    {
      "type": "text",
      "id": "customer_service_title",
      "label": "Customer Service Title",
      "default": "Customer Service"
    },
    {
      "type": "textarea",
      "id": "customer_service_desc",
      "label": "Customer Service Description",
      "default": "We reply within 24 hours"
    },
    {
      "type": "text",
      "id": "customer_service_email",
      "label": "Customer Service Email",
      "default": "support@ulphysync.store"
    },
    {
      "type": "header",
      "content": "Helpline Box"
    },
    {
      "type": "text",
      "id": "helpline_title",
      "label": "Helpline Title",
      "default": "Helpline"
    },
    {
      "type": "textarea",
      "id": "helpline_desc",
      "label": "Helpline Description",
      "default": "Call us for quick support"
    },
    {
      "type": "text",
      "id": "helpline_phone",
      "label": "Helpline Phone",
      "default": "+1 800 656 1234"
    },
    {
      "type": "header",
      "content": "Address Box"
    },
    {
      "type": "text",
      "id": "address_title",
      "label": "Address Title",
      "default": "Our Address"
    },
    {
      "type": "textarea",
      "id": "address_details",
      "label": "Address Details",
      "default": "1234 Business St, New York, NY 10001, USA"
    },
    {
      "type": "text",
      "id": "additional_phone",
      "label": "Additional Phone",
      "default": "+1 800 789 5678"
    }
  ],
  "presets": [
    {
      "name": "Contact Boxes"
    }
  ]
}
{% endschema %}
