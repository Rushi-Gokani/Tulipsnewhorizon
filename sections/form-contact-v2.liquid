{{- 'form-contact.css' | asset_url | stylesheet_tag -}}

{%- style -%}
  #shopify-section-{{ section.id }} > div {
    padding-block-start: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_top }});
    padding-block-end: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_bottom }});
  }

  /* Force labels to be visible and above inputs */
  #shopify-section-{{ section.id }} .field__label,
  #shopify-section-{{ section.id }} label.field__label,
  #shopify-section-{{ section.id }} .field > label {
    display: block !important;
    visibility: visible !important;
    opacity: 1 !important;
    position: relative !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    color: #2d3748 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.5px !important;
    margin: 0 0 8px 0 !important;
    padding: 0 !important;
  }

  #shopify-section-{{ section.id }} .field__label__required {
    color: #e53e3e !important;
    margin-left: 2px;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="form-container">
    <div class="form-contact">
      <div class="container form-contact__inner">
        {%- form 'contact', id: 'ContactForm', class: 'contact-form grid' -%}
          {%- if form.posted_successfully? -%}
            <p class="form-contact__message--success h4 col-span-6" tabindex="-1" autofocus>
              Thanks for contacting us. We'll get back to you as soon as possible.
            </p>
          {%- elsif form.errors -%}
            <div class="color-red">
              {{- form.errors | default_errors -}}
            </div>
          {%- endif -%}

          {%- assign field_type_list = '' -%}
          {% for block in section.blocks %}
            {%- assign field_type_list = field_type_list | append: block.settings.type | append: ',' -%}

            <div class="col-span-{{ block.settings.column_factor }}" {{ block.shopify_attributes }}>
              {% liquid
                assign label_default = 'field-' | append: forloop.index
                assign label = block.settings.heading | default: label_default
                assign label_handle = label | handle
                assign id = 'ContactForm-' | append: label_handle
                assign name = 'contact[' | append: label_handle | replace: '-', '_' | append: ']'
                assign placeholder = block.settings.placeholder | default: false
                assign required = block.settings.required | default: false

                case block.settings.type
                  when 'email'
                    capture attr
                      echo 'autocomplete="email"'
                      echo 'spellcheck="false"'
                      echo 'autocapitalize="off"'
                    endcapture

                    # overwrite: generated name from label: email field is single/uniqu field and needs static pre-defined name
                    assign name = 'contact[email]'

                    if form.email
                      assign value = form.email
                    elsif customer
                      assign value = customer.email
                    else
                      assign value = ''
                    endif

                    if form.errors contains 'email'
                      assign error = form.errors.translated_fields.email | capitalize | append: ' ' | append: form.errors.messages.email
                      assign has_error = true
                    endif

                    render 'text-input', type: 'email', id: id, label: label, name: name, placeholder: placeholder, required: required, attr: attr, value: value, has_error: has_error, message: error

                  when 'tel'
                    capture attr
                      echo 'autocomplete="tel"'
                    endcapture
                    if form.phone
                      assign value = form.phone
                    elsif customer
                      assign value = customer.phone
                    else
                      assign value = ''
                    endif
                    render 'text-input', type: 'tel', id: id, label: label, name: name, placeholder: placeholder, required: required, attr: attr, value: value, has_error: has_error, message: error

                  when 'checkbox'
                    assign label = block.settings.label_description | default: label
                    assign required = ''
                    if block.settings.required
                      assign required = ' required'
                    endif
                    echo '<div class="flex checkbox">'
                    echo '<label class="field__label" for="' | append: id | append: '">' | append: label | append: '</label>'
                    echo '<div class="field__options">'
                    for i in (1..4)
                      assign checked = ''
                      if forloop.first and block.settings.checked
                        assign checked = ' checked'
                      endif
                      assign option_name = 'option_' | append: i
                      assign option = block.settings[option_name]
                      if option != blank
                        echo '<div class="field__option"><input type="checkbox" name="' | append: name | append: '" value="' | append: option | append: '" id="' | append: id | append: '-' | append: option | append: '"' | append: required | append: checked | append: '><label for="' | append: id | append: '-' | append: option | append: '">' | append: option | append: '</label></div>'
                      endif
                    endfor
                    echo '</div>'
                    echo '</div>'

                  when 'radio'
                    assign label = block.settings.label_description | default: label
                    assign required = ''
                    if block.settings.required
                      assign required = ' required'
                    endif
                    echo '<div class="flex checkbox">'
                    echo '<label class="field__label" for="' | append: id | append: '">' | append: label | append: '</label>'
                    echo '<div class="field__options">'
                    for i in (1..4)
                      assign checked = ''
                      if forloop.first and block.settings.checked
                        assign checked = ' checked'
                      endif
                      assign option_name = 'option_' | append: i
                      assign option = block.settings[option_name]
                      if option != blank
                        echo '<div class="field__option"><input type="radio" name="' | append: name | append: '" value="' | append: option | append: '" id="' | append: id | append: '-' | append: option | append: '"' | append: required | append: checked | append: '><label for="' | append: id | append: '-' | append: option | append: '">' | append: option | append: '</label></div>'
                      endif
                    endfor
                    echo '</div>'
                    echo '</div>'

                  when 'select'
                    assign options_string = block.settings.select_options | default: 'Option 1,Option 2,Option 3'
                    assign options = options_string | split: ','
                    assign select_placeholder = block.settings.placeholder | default: 'Select an option'
                    assign required_attr = ''
                    if required
                      assign required_attr = 'required'
                    endif
                    echo '<label class="field__label" for="' | append: id | append: '">' | append: label | append: '</label>'
                    echo '<select name="' | append: name | append: '" id="' | append: id | append: '" class="form-control" ' | append: required_attr | append: '>'
                    echo '<option value="" disabled selected>' | append: select_placeholder | append: '</option>'
                    for option in options
                      echo '<option value="' | append: option | append: '">' | append: option | append: '</option>'
                    endfor
                    echo '</select>'

                  when 'textarea'
                    assign textarea_placeholder = block.settings.placeholder | default: placeholder
                    assign required_attr = ''
                    if required
                      assign required_attr = 'required'
                    endif
                    echo '<label class="field__label" for="' | append: id | append: '">' | append: label | append: '</label>'
                    echo '<textarea id="' | append: id | append: '" name="' | append: name | append: '" placeholder="' | append: textarea_placeholder | append: '" ' | append: required_attr | append: ' rows="5" class="field__input field__textarea">' | append: form[label_handle] | append: '</textarea>'

                  else
                    if block.settings.binding != 'custom'
                      if form[label_handle]
                        assign value = form[label_handle]
                      elsif customer
                        case block.settings.binding
                          when 'email'
                            assign value = customer.email
                          when 'name'
                            assign value = customer.name
                          when 'first_name'
                            assign value = customer.first_name
                          when 'last_name'
                            assign value = customer.last_name
                          when 'id'
                            assign value = customer.id
                          when 'phone'
                            assign value = customer.phone
                          when 'last_order'
                            assign customer_last_order = customer.orders | last
                            assign value = customer_last_order.order_number
                        endcase
                      else
                        assign value = ''
                      endif
                    endif

                    render 'text-input', type: 'text', id: id, label: label, name: name, placeholder: placeholder, required: required, value: value, has_error: has_error, message: error
                endcase
              %}
            </div>
          {% endfor %}

          <div class="form-row form-row--actions col-span-6">
            <button type="submit" class="button submit-button">SUBMIT</button>
          </div>
        {%- endform -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact Form",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Global Settings"
    },
    {
      "type": "select",
      "id": "section_width",
      "options": [
        {
          "value": "max-w-page",
          "label": "Page Width"
        },
        {
          "value": "max-w-narrower",
          "label": "Narrower"
        },
        {
          "value": "max-w-fluid",
          "label": "Fluid"
        }
      ],
      "default": "max-w-narrower",
      "label": "Section Width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-1",
      "label": "Color Scheme"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "Spacing Top",
      "options": [
        {
          "value": "0",
          "label": "No"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "Spacing Bottom",
      "options": [
        {
          "value": "0",
          "label": "No"
        },
        {
          "value": "1",
          "label": "S"
        },
        {
          "value": "2",
          "label": "M"
        },
        {
          "value": "4",
          "label": "L"
        },
        {
          "value": "6",
          "label": "XL"
        }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Subject Field Settings"
    },
    {
      "type": "text",
      "id": "subject_label",
      "label": "Subject Label",
      "default": "SELECT THE SUBJECT"
    },
    {
      "type": "text",
      "id": "subject_placeholder",
      "label": "Subject Placeholder",
      "default": "Select an option"
    },
    {
      "type": "textarea",
      "id": "subject_options",
      "label": "Subject Options",
      "default": "General Inquiry,Order Issue,Product Information,Technical Support,Other"
    },
    {
      "type": "checkbox",
      "id": "subject_required",
      "label": "Subject Required",
      "default": true
    },
    {
      "type": "header",
      "content": "Message Field Settings"
    },
    {
      "type": "text",
      "id": "message_label",
      "label": "Message Label",
      "default": "MESSAGE"
    },
    {
      "type": "text",
      "id": "message_placeholder",
      "label": "Message Placeholder",
      "default": "Your message"
    }
  ],
  "blocks": [
    {
      "type": "field",
      "name": "Form Field",
      "settings": [
        {
          "type": "select",
          "id": "column_factor",
          "options": [
            {
              "value": "6",
              "label": "Full Width"
            },
            {
              "value": "3",
              "label": "Half Width"
            }
          ],
          "default": "6",
          "label": "Column Width"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Field Heading",
          "default": "Label"
        },
        {
          "type": "select",
          "id": "type",
          "label": "Field Type",
          "options": [
            {
              "value": "text",
              "label": "Text"
            },
            {
              "value": "email",
              "label": "Email"
            },
            {
              "value": "tel",
              "label": "Phone"
            },
            {
              "value": "select",
              "label": "Dropdown"
            },
            {
              "value": "textarea",
              "label": "Textarea"
            },
            {
              "value": "checkbox",
              "label": "Checkbox"
            },
            {
              "value": "radio",
              "label": "Radio"
            }
          ],
          "default": "text"
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "Required",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "checked",
          "label": "Checked by Default",
          "default": false
        },
        {
          "type": "text",
          "id": "placeholder",
          "label": "Placeholder"
        },
        {
          "type": "textarea",
          "id": "select_options",
          "label": "Dropdown Options",
          "info": "Enter options separated by commas (e.g., Option 1,Option 2,Option 3)",
          "default": "Option 1,Option 2,Option 3"
        },
        {
          "type": "select",
          "id": "binding",
          "label": "Field Binding",
          "options": [
            {
              "value": "custom",
              "label": "Custom"
            },
            {
              "value": "email",
              "label": "Email"
            },
            {
              "value": "name",
              "label": "Name"
            },
            {
              "value": "first_name",
              "label": "First Name"
            },
            {
              "value": "last_name",
              "label": "Last Name"
            },
            {
              "value": "id",
              "label": "ID"
            },
            {
              "value": "phone",
              "label": "Phone"
            },
            {
              "value": "last_order",
              "label": "Last Order"
            }
          ],
          "default": "custom"
        },
        {
          "type": "header",
          "content": "Options Settings"
        },
        {
          "type": "text",
          "id": "label_description",
          "label": "Label Description"
        },
        {
          "type": "text",
          "id": "option_1",
          "label": "Option 1"
        },
        {
          "type": "text",
          "id": "option_2",
          "label": "Option 2"
        },
        {
          "type": "text",
          "id": "option_3",
          "label": "Option 3"
        },
        {
          "type": "text",
          "id": "option_4",
          "label": "Option 4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact Form",
      "blocks": []
    }
  ]
}
{% endschema %}
