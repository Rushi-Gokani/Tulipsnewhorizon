{%- style -%}
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .overlap-badge-card__container {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    padding-top: 30px; /* Space for the floating badge */
  }

  /* The Pill Header */
  .overlap-badge-card__pill {
    background: #ffffff;
    border-radius: 999px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    border: 1px solid rgba(0,0,0,0.03);
    padding: 10px 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    position: relative;
    z-index: 3;
    margin-bottom: -35px; /* Overlaps the card below */
    transition: transform 0.3s ease;
  }

  .overlap-badge-card__pill-icon {
    display: flex;
    width: 70px;
    height: 70px;
    flex-shrink: 0;
  }

  .overlap-badge-card__pill-icon img,
  .overlap-badge-card__pill-icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .overlap-badge-card__pill-title {
    margin: 0;
    font-size: 2.3rem;
    font-weight: 700;
    color: #000000;
    letter-spacing: 1px;
    text-transform: uppercase;
    line-height: 1;

  }

  /* The Card Content */
  .overlap-badge-card__content {
    background: {{ section.settings.card_bg_color }};
    border-radius: 12px;
    border: 1px solid rgba(0,0,0,0.04);
    padding: 75px 30px 40px; /* Top padding is large to accommodate the overlap */
    width: 100%;
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .overlap-badge-card__text {
    margin: 0 auto;
    max-width: 850px;
    color: #666666;
    font-size: 1.3rem;
    line-height: 1.6;
    font-weight: 400;
  }

  /* Read More Styling */
  .overlap-badge-card__text .read-more-toggle.inline-toggle {
    color: {{ section.settings.link_color }};
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    margin-left: 5px;
    transition: opacity 0.2s ease;
  }

  .overlap-badge-card__text .read-more-toggle.inline-toggle:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .overlap-badge-card__pill {
      padding: 8px 25px;
      gap: 10px;
      margin-bottom: -30px;
    }
    .overlap-badge-card__pill-icon {
      width: 50px;
      height: 50px;
    }
    .overlap-badge-card__pill-title {
      font-size: 1.8rem;
    }
    .overlap-badge-card__content {
      padding: 60px 20px 30px;
    }
    .overlap-badge-card__text {
      font-size: 1rem;
    }
  }
{%- endstyle -%}

<div class="overlap-badge-card section-{{ section.id }} page-width">
  <div class="overlap-badge-card__container">
    
    <!-- Floating Pill Badge -->
    <div class="overlap-badge-card__pill">
      {%- if section.settings.icon != blank -%}
        <div class="overlap-badge-card__pill-icon">
          {{ section.settings.icon | image_url: width: 100 | image_tag: loading: 'lazy' }}
        </div>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="overlap-badge-card__pill-title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    <!-- Main Card Content -->
    <div class="overlap-badge-card__content">
      {%- if section.settings.description != blank -%}
        <div class="overlap-badge-card__text">
          <read-more-text data-limit="{{ section.settings.read_more_limit }}" style="display: contents;">
            <div class="read-more-content rte" data-full-text>
               {{ section.settings.description }}
            </div>
          </read-more-text>
        </div>
      {%- endif -%}
      </div>
     </div>

 </div>

<script src="{{ 'read-more-text.js' | asset_url }}"></script>

{% schema %}
{
  "name": "Overlap Badge Card",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Badge Settings"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Badge Icon"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Badge Title",
      "default": "Adult Diapers"
    },
    {
      "type": "header",
      "content": "Card Settings"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>TULIPS Adult Diaper Pants & Tape style are an effective option for both men and women who are experiencing incontinence and bladder issues. Composed of soft fabrics...</p>"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#FAFAF5"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Read More Color",
      "default": "#A3CA6D"
    },
    {
      "type": "range",
      "id": "read_more_limit",
      "min": 10,
      "max": 100,
      "step": 5,
      "label": "Read More Word Limit",
      "default": 15
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Overlap Badge Card"
    }
  ]
}
{% endschema %}
