
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .product-breadcrumb {
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
  }

  .product-breadcrumb__inner {
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.alignment | default: 'center' }};
    gap: 1.5rem;
    max-width: 100%;
    margin: 0 auto;
  }

  .product-breadcrumb__nav {
    display: flex;
    align-items: center;
    min-width: 32px;
  }

  .product-breadcrumb__arrow {
    text-decoration: none;
    color: inherit;
    display: flex;
    align-items: center;
    transition: opacity 0.2s ease;
  }

  .product-breadcrumb__arrow:hover {
    opacity: 0.7;
  }

  .product-breadcrumb__arrow-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background-color: {{ section.settings.arrow_bg_color | default: section.settings.text_color }};
    color: {{ section.settings.arrow_icon_color | default: section.settings.background_color }};
    border-radius: 50%;
  }

  .product-breadcrumb__arrow-circle svg {
    width: 8px;
    height: 8px;
  }

  .product-breadcrumb__nav--prev .product-breadcrumb__arrow-circle svg {
    transform: rotate(90deg);
  }

  .product-breadcrumb__nav--next .product-breadcrumb__arrow-circle svg {
    transform: rotate(-90deg);
  }

  .product-breadcrumb__links {
    display: flex;
    align-items: center;
    font-size: 0.9rem;
    font-weight: 500;
    flex-wrap: wrap;
    line-height: 1.4;
  }

  .product-breadcrumb__links a {
    text-decoration: none;
    color: inherit;
    opacity: 0.7;
    transition: all 0.2s ease;
    border-bottom: 1px solid transparent;
  }

  .product-breadcrumb__links a:hover {
    opacity: 1;
    border-bottom-color: currentColor;
  }

  .product-breadcrumb__divider {
    margin: 0 10px;
    opacity: 0.4;
    font-weight: 300;
  }

  .product-breadcrumb__current {
    font-weight: 500;
    opacity: 0.6;
    color: {{ section.settings.text_color }};
  }

  @media screen and (max-width: 749px) {
    .product-breadcrumb__inner {
      gap: 0.5rem;
      padding: 0 1rem;
    }
    .product-breadcrumb__links {
      font-size: 1rem;
    }
    .product-breadcrumb__divider {
      margin: 0 6px;
    }
  }
{%- endstyle -%}

<div class="product-breadcrumb section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="product-breadcrumb__inner">
      {%- if section.settings.show_nav_arrows -%}
        <div class="product-breadcrumb__nav product-breadcrumb__nav--prev">
          {%- if collection.previous_product -%}
            <a href="{{ collection.previous_product.url }}" class="product-breadcrumb__arrow" aria-label="{{ 'products.product.prev_product' | t | default: 'Previous product' }}">
              <span class="product-breadcrumb__arrow-circle">
                {% render 'icon', icon: 'caret' %}
              </span>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      <nav class="product-breadcrumb__links" role="navigation" aria-label="breadcrumbs">
        <a href="{{ routes.root_url }}" title="Home">Home</a>
        
        {%- liquid
          assign target_collection = collection
          if target_collection.handle == 'all'
            assign target_collection = blank
          endif
          
          if target_collection == blank and product.collections.size > 0
            for col in product.collections
              if col.handle == 'all'
                continue
              endif
              
              assign first_char = col.title | slice: 0
              assign digits = "0123456789"
              unless digits contains first_char
                assign target_collection = col
                break
              endunless
            endfor
            
            if target_collection == blank
              for col in product.collections
                if col.handle != 'all'
                  assign target_collection = col
                  break
                endif
              endfor
            endif
          endif
        -%}

        {%- if target_collection -%}
          {%- liquid
            assign parent_handle = ""
            assign current_handle = target_collection.handle
            
            # Check for parent mapping in blocks
            for block in section.blocks
              if block.type == 'parent_map'
                assign child_handles = block.settings.child_collections | split: ','
                for handle in child_handles
                  assign h = handle | strip
                  if h == current_handle
                    assign parent_handle = block.settings.parent_collection
                    break
                  endif
                endfor
              endif
              if parent_handle != ""
                break
              endif
            endfor

            assign collection_title = target_collection.title
            if section.settings.title_override != blank and section.settings.collection_to_override == target_collection.handle
              assign collection_title = section.settings.title_override
            endif
          -%}

          {%- if parent_handle != blank -%}
             {%- assign parent_col = collections[parent_handle] -%}
             {%- if parent_col != blank -%}
                <span class="product-breadcrumb__divider" aria-hidden="true">></span>
                <a href="{{ parent_col.url }}" title="{{ parent_col.title | escape }}">{{ parent_col.title | escape }}</a>
             {%- endif -%}
          {%- endif -%}

          <span class="product-breadcrumb__divider" aria-hidden="true">></span>
          <a href="{{ target_collection.url }}" title="{{ collection_title | escape }}">{{ collection_title | escape }}</a>
        {%- endif -%}

        <span class="product-breadcrumb__divider" aria-hidden="true">></span>
        <span class="product-breadcrumb__current">{{ product.title | escape }}</span>
      </nav>

      {%- if section.settings.show_nav_arrows -%}
        <div class="product-breadcrumb__nav product-breadcrumb__nav--next">
          {%- if collection.next_product -%}
            <a href="{{ collection.next_product.url }}" class="product-breadcrumb__arrow" aria-label="{{ 'products.product.next_product' | t | default: 'Next product' }}">
              <span class="product-breadcrumb__arrow-circle">
                {% render 'icon', icon: 'caret' %}
              </span>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Breadcrumb",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fffbeb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#3730a3"
    },
    {
      "type": "checkbox",
      "id": "show_nav_arrows",
      "label": "Show navigation arrows",
      "default": false
    },
    {
      "type": "header",
      "content": "Title Overrides"
    },
    {
      "type": "collection",
      "id": "collection_to_override",
      "label": "Collection to override"
    },
    {
      "type": "text",
      "id": "title_override",
      "label": "New title",
      "info": "Display this title instead of the original collection title"
    },
    {
      "type": "header",
      "content": "Arrow Styling"
    },
    {
      "type": "color",
      "id": "arrow_bg_color",
      "label": "Arrow background color",
      "info": "Leave empty to use text color"
    },
    {
      "type": "color",
      "id": "arrow_icon_color",
      "label": "Arrow icon color",
      "info": "Leave empty to use background color"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "parent_map",
      "name": "Parent Collection Map",
      "settings": [
        {
          "type": "collection",
          "id": "parent_collection",
          "label": "Parent Collection"
        },
        {
          "type": "textarea",
          "id": "child_collections",
          "label": "Child Collection Handles",
          "info": "Comma-separated list of child collection handles"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Breadcrumb",
      "blocks": [
        {
          "type": "parent_map",
          "settings": {
            "parent_collection": "our-products",
            "child_collections": "adult-diaper-pants,baby-range,bathing-range,cotton,kitchen-dining,makeup-remover-range,toilet-rolls,wipes-tissues"
          }
        }
      ]
    }
  ]
}
{% endschema %}
