
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .product-breadcrumb {
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
  }

  .product-breadcrumb__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    max-width: 100%;
    margin: 0 auto;
  }

  .product-breadcrumb__nav {
    display: flex;
    align-items: center;
    min-width: 32px;
  }

  .product-breadcrumb__arrow {
    text-decoration: none;
    color: inherit;
    display: flex;
    align-items: center;
    transition: opacity 0.2s ease;
  }

  .product-breadcrumb__arrow:hover {
    opacity: 0.7;
  }

  .product-breadcrumb__arrow-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background-color: {{ section.settings.arrow_bg_color | default: section.settings.text_color }};
    color: {{ section.settings.arrow_icon_color | default: section.settings.background_color }};
    border-radius: 50%;
  }

  .product-breadcrumb__arrow-circle svg {
    width: 8px;
    height: 8px;
  }

  .product-breadcrumb__nav--prev .product-breadcrumb__arrow-circle svg {
    transform: rotate(90deg);
  }

  .product-breadcrumb__nav--next .product-breadcrumb__arrow-circle svg {
    transform: rotate(-90deg);
  }

  .product-breadcrumb__links {
    display: flex;
    align-items: center;
    font-size: 1.1rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .product-breadcrumb__links a {
    text-decoration: none;
    color: inherit;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }

  .product-breadcrumb__links a:hover {
    opacity: 1;
  }

  .product-breadcrumb__divider {
    margin: 0 12px;
    opacity: 0.5;
  }

  .product-breadcrumb__current {
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media screen and (max-width: 749px) {
    .product-breadcrumb__inner {
      gap: 1rem;
    }
    .product-breadcrumb__links {
      font-size: 0.9rem;
    }
    .product-breadcrumb__divider {
      margin: 0 8px;
    }
  }
{%- endstyle -%}

<div class="product-breadcrumb section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="product-breadcrumb__inner">
      <div class="product-breadcrumb__nav product-breadcrumb__nav--prev">
        {%- if collection.previous_product -%}
          <a href="{{ collection.previous_product.url }}" class="product-breadcrumb__arrow" aria-label="{{ 'products.product.prev_product' | t | default: 'Previous product' }}">
            <span class="product-breadcrumb__arrow-circle">
              {% render 'icon', icon: 'caret' %}
            </span>
          </a>
        {%- endif -%}
      </div>

      <nav class="product-breadcrumb__links" role="navigation" aria-label="breadcrumbs">
        <a href="{{ routes.root_url }}" title="Home">Home</a>
        
        {%- if collection -%}
          <span class="product-breadcrumb__divider" aria-hidden="true">/</span>
          <a href="{{ collection.url }}" title="{{ collection.title | escape }}">{{ collection.title | escape }}</a>
        {%- elsif product.collections.size > 0 -%}
          {%- assign first_collection = product.collections.first -%}
          <span class="product-breadcrumb__divider" aria-hidden="true">/</span>
          <a href="{{ first_collection.url }}" title="{{ first_collection.title | escape }}">{{ first_collection.title | escape }}</a>
        {%- endif -%}

        <span class="product-breadcrumb__divider" aria-hidden="true">/</span>
        <span class="product-breadcrumb__current">{{ product.title | escape }}</span>
      </nav>

      <div class="product-breadcrumb__nav product-breadcrumb__nav--next">
        {%- if collection.next_product -%}
          <a href="{{ collection.next_product.url }}" class="product-breadcrumb__arrow" aria-label="{{ 'products.product.next_product' | t | default: 'Next product' }}">
            <span class="product-breadcrumb__arrow-circle">
              {% render 'icon', icon: 'caret' %}
            </span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Breadcrumb",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fffbeb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#3730a3"
    },
    {
      "type": "header",
      "content": "Arrow Styling"
    },
    {
      "type": "color",
      "id": "arrow_bg_color",
      "label": "Arrow background color",
      "info": "Leave empty to use text color"
    },
    {
      "type": "color",
      "id": "arrow_icon_color",
      "label": "Arrow icon color",
      "info": "Leave empty to use background color"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Product Breadcrumb"
    }
  ]
}
{% endschema %}
