
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .product-breadcrumb {
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
  }

  .product-breadcrumb__inner {
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.alignment | default: 'center' }};
    gap: 1.5rem;
    max-width: 100%;
    margin: 0 auto;
  }

  .product-breadcrumb__nav {
    display: flex;
    align-items: center;
    min-width: 32px;
  }

  .product-breadcrumb__arrow {
    text-decoration: none;
    color: inherit;
    display: flex;
    align-items: center;
    transition: opacity 0.2s ease;
  }

  .product-breadcrumb__arrow:hover {
    opacity: 0.7;
  }

  .product-breadcrumb__arrow-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background-color: {{ section.settings.arrow_bg_color | default: section.settings.text_color }};
    color: {{ section.settings.arrow_icon_color | default: section.settings.background_color }};
    border-radius: 50%;
  }

  .product-breadcrumb__arrow-circle svg {
    width: 8px;
    height: 8px;
  }

  .product-breadcrumb__nav--prev .product-breadcrumb__arrow-circle svg {
    transform: rotate(90deg);
  }

  .product-breadcrumb__nav--next .product-breadcrumb__arrow-circle svg {
    transform: rotate(-90deg);
  }

  .product-breadcrumb__links {
    display: flex;
    align-items: center;
    font-size: 0.9rem;
    font-weight: 500;
    flex-wrap: wrap;
    line-height: 1.4;
  }

  .product-breadcrumb__links a {
    text-decoration: none;
    color: inherit;
    opacity: 0.7;
    transition: all 0.2s ease;
    border-bottom: 1px solid transparent;
  }

  .product-breadcrumb__links a:hover {
    opacity: 1;
    border-bottom-color: currentColor;
  }

  .product-breadcrumb__divider {
    margin: 0 10px;
    opacity: 0.4;
    font-weight: 300;
  }

  .product-breadcrumb__current {
    font-weight: 500;
    opacity: 0.6;
    color: {{ section.settings.text_color }};
  }

  @media screen and (max-width: 749px) {
    .product-breadcrumb__inner {
      gap: 0.5rem;
      padding: 0 1rem;
    }
    .product-breadcrumb__links {
      font-size: 1rem;
    }
    .product-breadcrumb__divider {
      margin: 0 6px;
    }
  }
{%- endstyle -%}

<div class="product-breadcrumb section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="product-breadcrumb__inner">
      {%- if section.settings.show_nav_arrows -%}
        <div class="product-breadcrumb__nav product-breadcrumb__nav--prev">
          {%- if collection.previous_product -%}
            <a href="{{ collection.previous_product.url }}" class="product-breadcrumb__arrow" aria-label="{{ 'products.product.prev_product' | t | default: 'Previous product' }}">
              <span class="product-breadcrumb__arrow-circle">
                {% render 'icon', icon: 'caret' %}
              </span>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      <nav class="product-breadcrumb__links" role="navigation" aria-label="breadcrumbs">
        <a href="{{ routes.root_url }}" title="Home">Home</a>
        
        {%- liquid
          assign target_collection = blank
          assign excluded_handles = 'all-products,best-seller,all,our-products,bathroom-essentials,bathing-bar-soap,home,home-page,frontpage'
          
          if product.collections.size > 0
            assign min_count = 9999999
            
            for col in product.collections
              if col.handle != blank
                assign col_handle = col.handle | downcase
                assign is_numeric = false
                assign string_to_check = col.title | remove: '0' | remove: '1' | remove: '2' | remove: '3' | remove: '4' | remove: '5' | remove: '6' | remove: '7' | remove: '8' | remove: '9' | remove: '.' | remove: ',' | remove: ' ' | remove: '-'
                if string_to_check == blank
                  assign is_numeric = true
                endif
                
                unless excluded_handles contains col_handle or col_handle contains 'gst' or col_handle contains 'tax' or is_numeric
                  
                  assign is_parent_with_child = false
                  for block in section.blocks
                    if block.type == 'parent_map'
                      assign block_parent = block.settings.parent_collection | handleize
                      if col_handle == block_parent
                        assign child_handles = block.settings.child_collections | split: ','
                        for c_handle in child_handles
                          assign cleaned_child = c_handle | strip | handleize
                          for prod_col in product.collections
                            assign prod_col_handle = prod_col.handle | downcase
                            if prod_col_handle == cleaned_child
                              assign is_parent_with_child = true
                              break
                            endif
                          endfor
                          if is_parent_with_child
                            break
                          endif
                        endfor
                      endif
                    endif
                    if is_parent_with_child
                      break
                    endif
                  endfor

                  if is_parent_with_child == false
                    if col.all_products_count < min_count
                      assign target_collection = col
                      assign min_count = col.all_products_count
                    endif
                  endif
                  
                endunless
              endif
            endfor
          endif
          
          if target_collection == blank
            if product.collections.size > 0
              for col in product.collections
                assign col_handle = col.handle | downcase
                assign is_numeric = false
                assign string_to_check = col.title | remove: '0' | remove: '1' | remove: '2' | remove: '3' | remove: '4' | remove: '5' | remove: '6' | remove: '7' | remove: '8' | remove: '9' | remove: '.' | remove: ',' | remove: ' ' | remove: '-'
                if string_to_check == blank
                  assign is_numeric = true
                endif
                unless col_handle == 'home' or col_handle == 'home-page' or col_handle == 'frontpage' or col_handle == 'all' or col_handle == 'all-products' or is_numeric
                  assign target_collection = col
                  break
                endunless
              endfor
            endif
          endif
        -%}

        {%- if target_collection != blank -%}
          {%- liquid
            assign current_handle = target_collection.handle | downcase
            
            for block in section.blocks
              if block.type == 'parent_map'
                assign parent_h = block.settings.parent_collection | handleize
                
                if current_handle == parent_h
                  for child_col in product.collections
                    assign child_h = child_col.handle | downcase
                    if child_h != current_h
                      assign child_handles = block.settings.child_collections | split: ','
                      for handle in child_handles
                        assign h = handle | strip | handleize
                        if h == child_h
                          assign target_collection = child_col
                          break
                        endif
                      endfor
                    endif
                  endfor
                endif
              endif
            endfor

            assign collection_title = target_collection.title

            assign target_col_handle = target_collection.handle | downcase
            assign target_col_title_lower = collection_title | downcase
            assign is_soap = false
            
            if target_col_handle contains 'soap' or target_col_handle contains 'bathing' or target_col_title_lower contains 'soap' or target_col_title_lower contains 'bathing'
              assign is_soap = true
            endif
            
            if product.type != blank
              assign prod_type_lower = product.type | downcase
              if prod_type_lower contains 'soap' or prod_type_lower contains 'bathing'
                assign is_soap = true
              endif
            endif
            
            if is_soap
              assign collection_title = 'Handmade Soaps'
            endif

            if section.settings.title_override != blank and section.settings.collection_to_override == target_collection.handle
              assign collection_title = section.settings.title_override
            endif
          -%}

          <span class="product-breadcrumb__divider" aria-hidden="true">></span>
          <a href="{{ target_collection.url }}" title="{{ collection_title | escape }}">{{ collection_title | escape }}</a>
        {%- elsif product.type != blank -%}
          <span class="product-breadcrumb__divider" aria-hidden="true">></span>
          <a href="{{ routes.collections_url }}/all?filter.p.product_type={{ product.type | url_encode }}" title="{{ product.type | escape }}">{{ product.type | escape }}</a>
        {%- else -%}
          <span class="product-breadcrumb__divider" aria-hidden="true">></span>
          <a href="{{ routes.all_products_collection_url }}" title="{{ 'Products' | escape }}">{{ 'Products' | escape }}</a>
        {%- endif -%}

        <span class="product-breadcrumb__divider" aria-hidden="true">></span>
        <span class="product-breadcrumb__current">{{ product.title | escape }}</span>
      </nav>

      {%- if section.settings.show_nav_arrows -%}
        <div class="product-breadcrumb__nav product-breadcrumb__nav--next">
          {%- if collection.next_product -%}
            <a href="{{ collection.next_product.url }}" class="product-breadcrumb__arrow" aria-label="{{ 'products.product.next_product' | t | default: 'Next product' }}">
              <span class="product-breadcrumb__arrow-circle">
                {% render 'icon', icon: 'caret' %}
              </span>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Breadcrumb",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fffbeb"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#3730a3"
    },
    {
      "type": "checkbox",
      "id": "show_nav_arrows",
      "label": "Show navigation arrows",
      "default": false
    },
    {
      "type": "header",
      "content": "Title Overrides"
    },
    {
      "type": "collection",
      "id": "collection_to_override",
      "label": "Collection to override"
    },
    {
      "type": "text",
      "id": "title_override",
      "label": "New title",
      "info": "Display this title instead of the original collection title"
    },
    {
      "type": "header",
      "content": "Arrow Styling"
    },
    {
      "type": "color",
      "id": "arrow_bg_color",
      "label": "Arrow background color",
      "info": "Leave empty to use text color"
    },
    {
      "type": "color",
      "id": "arrow_icon_color",
      "label": "Arrow icon color",
      "info": "Leave empty to use background color"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "parent_map",
      "name": "Parent Collection Map",
      "settings": [
        {
          "type": "collection",
          "id": "parent_collection",
          "label": "Parent Collection"
        },
        {
          "type": "textarea",
          "id": "child_collections",
          "label": "Child Collection Handles",
          "info": "Comma-separated list of child collection handles"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Breadcrumb",
      "blocks": [
        {
          "type": "parent_map",
          "settings": {
            "parent_collection": "our-products",
            "child_collections": "adult-diaper-pants,baby-range,bathing-range,cotton,kitchen-dining,makeup-remover-range,toilet-rolls,wipes-tissues"
          }
        }
      ]
    }
  ]
}
{% endschema %}
